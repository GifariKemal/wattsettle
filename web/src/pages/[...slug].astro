---
import PageShell from "../layouts/PageShell.astro";
import { pages } from "../content/nav";
import Home from "../components/pages/Home.astro";
import CaraKerja from "../components/pages/CaraKerja.astro";
import Demo from "../components/pages/Demo.astro";
import Enovatek from "../components/pages/Enovatek.astro";
import Teknologi from "../components/pages/Teknologi.astro";
import Roadmap from "../components/pages/Roadmap.astro";
import Tentang from "../components/pages/Tentang.astro";

export function getStaticPaths() {
  return pages.map((p) => ({ params: { slug: p.slug || undefined } }));
}

const MAP: Record<string, any> = {
  "": Home,
  "cara-kerja": CaraKerja,
  demo: Demo,
  enovatek: Enovatek,
  teknologi: Teknologi,
  roadmap: Roadmap,
  tentang: Tentang,
};

const slug = Astro.params.slug ?? "";
const Comp = MAP[slug];
---
<PageShell slug={slug}>
  <Comp />
</PageShell>
