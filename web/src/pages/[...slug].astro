---
import PageShell from "../layouts/PageShell.astro";
import { pages } from "../content/nav";
import Hero from "../components/sections/Hero.astro";
import Problem from "../components/sections/Problem.astro";
import SimulatorSection from "../components/sections/SimulatorSection.astro";
import Options from "../components/sections/Options.astro";
import CodexOptions from "../components/sections/CodexOptions.astro";
import Machine from "../components/sections/Machine.astro";
import MoneyFlow from "../components/sections/MoneyFlow.astro";
import Comparison from "../components/sections/Comparison.astro";
import Swot from "../components/sections/Swot.astro";
import Levers from "../components/sections/Levers.astro";
import Moat from "../components/sections/Moat.astro";
import Scoring from "../components/sections/Scoring.astro";
import Scenarios from "../components/sections/Scenarios.astro";
import Probability from "../components/sections/Probability.astro";
import PathTo90 from "../components/sections/PathTo90.astro";
import References from "../components/sections/References.astro";
import Prediction from "../components/sections/Prediction.astro";
import Footer from "../components/sections/Footer.astro";

export function getStaticPaths() {
  return pages.map((p) => ({ params: { slug: p.slug || undefined } }));
}

const MAP: Record<string, any> = {
  "": Hero,
  masalah: Problem,
  simulator: SimulatorSection,
  opsi: Options,
  codex: CodexOptions,
  mesin: Machine,
  "aliran-uang": MoneyFlow,
  banding: Comparison,
  swot: Swot,
  menang: Levers,
  moat: Moat,
  benchmark: Scoring,
  skenario: Scenarios,
  peluang: Probability,
  path: PathTo90,
  referensi: References,
  prediksi: Prediction,
  penutup: Footer,
};

const slug = Astro.params.slug ?? "";
const Comp = MAP[slug];
---
<PageShell slug={slug}>
  <Comp />
</PageShell>
