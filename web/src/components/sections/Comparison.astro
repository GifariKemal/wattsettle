---
import Section from "../ui/Section.astro";
import { comparison as c } from "../../content/options";
---
<Section
  id="banding"
  eyebrow={c.eyebrow}
  title={c.headline}
>
  <div class="cmp">
    <div class="tbl-scroll rv">
      <table class="tbl">
        <thead>
          <tr><th>Aspek</th><th>Opsi 5 · WattSettle</th><th>Opsi 6 · Enovatek</th></tr>
        </thead>
        <tbody>
          {c.rows.map((r) => (
            <tr>
              <td class="asp">{r.aspect}</td>
              <td data-l="Opsi 5 · WattSettle">{r.five}</td>
              <td class:list={[r.sixWin && "win"]} data-l="Opsi 6 · Enovatek">
                {r.six}{r.sixWin && <span class="win-mark" aria-label="unggul">✓</span>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="strategy rv" data-delay="120">
      <b>Strategi:</b> {c.strategy}
    </div>
  </div>
</Section>

<style>
  .cmp { display: flex; flex-direction: column; gap: 1.1rem; width: 100%; }
  .tbl-scroll { overflow-x: auto; border-radius: 1.2rem; border: 1px solid var(--edge); }
  .tbl { width: 100%; border-collapse: collapse; min-width: 620px; }
  .tbl th, .tbl td {
    text-align: left;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid var(--edge);
    font-size: 0.92rem;
    color: var(--color-muted);
  }
  .tbl th {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-faint);
    background: color-mix(in oklab, var(--color-ink) 3%, transparent);
  }
  .tbl tr:last-child td { border-bottom: none; }
  .tbl .asp { color: var(--color-ink); font-weight: 600; }
  .tbl .win { color: var(--color-flow); background: color-mix(in oklab, var(--color-flow) 7%, transparent); font-weight: 600; }
  .tbl .win-mark { margin-left: 0.4rem; font-weight: 700; }

  /* Mobile: tabel → kartu bertumpuk (tak ada kolom kepotong) */
  @media (max-width: 720px) {
    .tbl-scroll { overflow-x: visible; border: 0; border-radius: 0; }
    .tbl { min-width: 0; }
    .tbl thead { display: none; }
    .tbl tbody { display: flex; flex-direction: column; gap: 0.65rem; }
    .tbl tr {
      display: block;
      border: 1px solid var(--edge);
      border-radius: 1rem;
      padding: 0.85rem 1.05rem;
      background: color-mix(in oklab, var(--color-ink) 2%, transparent);
    }
    .tbl td { display: block; border: 0 !important; padding: 0.15rem 0; }
    .tbl td.asp {
      font-size: 0.98rem;
      border-bottom: 1px solid var(--edge) !important;
      padding-bottom: 0.45rem;
      margin-bottom: 0.4rem;
    }
    .tbl td.win { background: transparent; }
    .tbl td:not(.asp)::before {
      content: attr(data-l);
      display: block;
      font-family: var(--font-mono);
      font-size: 0.58rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-faint);
      margin-top: 0.4rem;
    }
  }
  .strategy {
    padding: 1.15rem 1.4rem;
    border-radius: 1.1rem;
    border: 1px solid color-mix(in oklab, var(--color-watt) 22%, transparent);
    background: color-mix(in oklab, var(--color-watt) 6%, transparent);
    color: var(--color-ink);
    line-height: 1.55;
    font-size: 0.94rem;
  }
  .strategy b { color: var(--color-watt); }
</style>
