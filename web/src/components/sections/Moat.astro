---
import Section from "../ui/Section.astro";
import { moat as m } from "../../content/why";
const sideCells = m.cells.slice(2); // BNB 2026 + Kurikulum (zkPull/OwnaFarm ada di Referensi)
---
<Section
  id="moat"
  eyebrow={m.eyebrow}
  title={m.headline}
  lead={m.lead}
>
  <div class="moat-grid">
    <div class="moat-main rv">
      <span class="lab">Moat 5-lapis</span>
      <h3>{m.bigTitle}</h3>
      <div class="layers">
        {m.layers.map((L) => (
          <div class="moat-row">
            <span class="k">{L.k}</span>
            <span>{L.body}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="moat-side">
      {sideCells.map((c, i) => (
        <div class="cell rv" data-delay={i * 90}>
          <span class="lab">{c.lab}</span>
          <h4>{c.title}</h4>
          <p>{c.body}</p>
        </div>
      ))}
    </div>
  </div>
</Section>

<style>
  .moat-grid { display: grid; gap: 1.1rem; grid-template-columns: 1fr; width: 100%; }
  @media (min-width: 940px) { .moat-grid { grid-template-columns: 1.35fr 0.65fr; align-items: stretch; } }

  .moat-main {
    padding: 1.7rem;
    border-radius: 1.3rem;
    border: 1px solid var(--edge);
    background:
      radial-gradient(90% 60% at 100% 0%, color-mix(in oklab, var(--color-watt) 9%, transparent), transparent 60%),
      linear-gradient(180deg, var(--color-panel), var(--color-panel-2));
    display: flex;
    flex-direction: column;
  }
  .moat-main .lab, .cell .lab {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-faint);
  }
  .moat-main h3 { font-size: clamp(1.3rem, 2.2vw, 1.75rem); margin: 0.5rem 0 1rem; }
  .layers { display: flex; flex-direction: column; gap: 0.6rem; margin-top: auto; }
  .moat-row {
    display: flex;
    gap: 0.85rem;
    align-items: center;
    padding: 0.7rem 0.95rem;
    border-radius: 0.8rem;
    background: linear-gradient(100deg, color-mix(in oklab, var(--color-watt) 6%, transparent), color-mix(in oklab, var(--color-ink) 3%, transparent) 45%);
    border: 1px solid var(--edge);
    border-left: 2px solid color-mix(in oklab, var(--color-watt) 40%, transparent);
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.4;
  }
  .moat-row .k { font-family: var(--font-mono); color: var(--color-watt); font-size: 0.85rem; flex-shrink: 0; }

  .moat-side { display: grid; gap: 1.1rem; grid-template-columns: 1fr; }
  @media (min-width: 500px) and (max-width: 939px) { .moat-side { grid-template-columns: 1fr 1fr; } }
  .cell {
    padding: 1.5rem;
    border-radius: 1.3rem;
    border: 1px solid var(--edge);
    background: linear-gradient(180deg, var(--color-panel), var(--color-panel-2));
    display: flex;
    flex-direction: column;
    justify-content: center;
    transition: transform 0.4s var(--ease-out-quint), border-color 0.4s ease;
  }
  .cell:hover { transform: translateY(-3px); border-color: var(--edge-strong); }
  .cell h4 { font-size: 1.1rem; margin: 0.45rem 0; }
  .cell p { color: var(--color-muted); font-size: 0.88rem; line-height: 1.5; }
</style>
