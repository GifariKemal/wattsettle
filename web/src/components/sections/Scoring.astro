---
import Section from "../ui/Section.astro";
import { scoring as s } from "../../content/scoring";
---
<Section
  id="benchmark"
  eyebrow={s.eyebrow}
  title={s.headline}
  lead={s.lead}
>
  <p class="score-legend rv"><b>skor</b> dari 100 · <b>nom</b> peluang nominasi · <b>juara</b> peluang juara-1 in-track</p>
  <div class="score-list">
    {s.rows.map((r, i) => (
      <div class:list={["score-row rv", r.winner && "winner", r.variant === "pivot" && "pivot", r.archived && "arch"]} data-delay={i * 60}>
        <div class="meta">
          <div class="id" title={`Opsi ${r.id}`}>O{r.id}</div>
          <div class="nm">
            <b>{r.name}</b>
            {r.badge && <span class:list={["badge", r.variant]}>{r.badge}</span>}
            <span class="track">{r.track}</span>
          </div>
        </div>
        <div class="bar-wrap">
          <div class="bar-track"><i class="bar-fill" data-bar={`${r.score}%`}></i></div>
          <div class="numbers">
            <span class="sc">{r.score}</span>
            <span class="pr">nom {r.nomination}</span>
            <span class="pr">juara {r.win}</span>
          </div>
        </div>
        <p class="note">{r.note}</p>
      </div>
    ))}
  </div>

  <p class="score-foot rv" data-delay="360">
    <b>O#</b> = nomor opsi, bukan peringkat. AgentCart TrustPay punya skor hype tertinggi dan layak jadi pivot jika track ramai energy/RWA. WattSettle x Enovatek tetap dipilih sebagai build utama karena bukti hardware + partner + revenue nyata lebih kuat untuk demo grand prize.
  </p>
</Section>

<style>
  .score-list { display: flex; flex-direction: column; gap: 0.55rem; width: 100%; }
  .score-foot { margin-top: 0.9rem; font-size: 0.76rem; line-height: 1.5; color: var(--color-faint); max-width: 90ch; }
  .score-foot b { font-family: var(--font-mono); color: var(--color-muted); }
  .score-row {
    display: grid;
    gap: 0.4rem 1.25rem;
    grid-template-columns: 1fr;
    padding: 0.9rem 1.2rem;
    border-radius: 1.05rem;
    border: 1px solid var(--edge);
    background: color-mix(in oklab, var(--color-ink) 2%, transparent);
    transition: border-color 0.4s ease, background 0.4s ease;
  }
  @media (min-width: 820px) { .score-row { grid-template-columns: 180px 1.1fr 1.2fr; align-items: center; } }
  .score-row.winner { border-color: color-mix(in oklab, var(--color-watt) 45%, transparent); background: color-mix(in oklab, var(--color-watt) 6%, transparent); }
  .score-row.pivot { border-color: color-mix(in oklab, var(--color-flow) 38%, transparent); background: color-mix(in oklab, var(--color-flow) 4%, transparent); }
  .score-row.arch { opacity: 0.72; }
  .score-legend { font-family: var(--font-mono); font-size: 0.68rem; color: var(--color-faint); margin-bottom: 0.35rem; letter-spacing: 0.03em; }
  .score-legend b { color: var(--color-muted); }
  .score-row.winner { box-shadow: 0 0 0 1px color-mix(in oklab, var(--color-watt) 30%, transparent), 0 18px 40px -28px color-mix(in oklab, var(--color-watt) 60%, transparent); }

  .meta { display: flex; align-items: center; gap: 0.85rem; }
  .meta .id {
    width: 2.1rem; height: 2.1rem;
    display: grid; place-items: center;
    border-radius: 0.65rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    border: 1px solid var(--edge);
    color: var(--color-faint);
    flex-shrink: 0;
  }
  .winner .meta .id { color: var(--color-watt); border-color: color-mix(in oklab, var(--color-watt) 45%, transparent); }
  .meta .nm { display: flex; flex-direction: column; }
  .meta .nm b { font-size: 0.98rem; }
  .badge {
    width: max-content;
    margin-top: 0.25rem;
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
    border: 1px solid var(--edge);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-faint);
  }
  .badge.chosen { color: var(--color-watt); border-color: color-mix(in oklab, var(--color-watt) 38%, transparent); }
  .badge.pivot { color: var(--color-flow); border-color: color-mix(in oklab, var(--color-flow) 38%, transparent); }
  .meta .track { font-family: var(--font-mono); font-size: 0.66rem; color: var(--color-faint); letter-spacing: 0.06em; }

  .bar-track { height: 0.5rem; border-radius: 999px; background: color-mix(in oklab, var(--color-ink) 7%, transparent); overflow: hidden; }
  .bar-fill { display: block; height: 100%; width: 0; border-radius: 999px; background: linear-gradient(90deg, var(--color-flow), var(--color-watt)); }
  .winner .bar-fill {
    background: linear-gradient(90deg, var(--color-watt), color-mix(in oklab, var(--color-watt) 55%, white), var(--color-watt));
    background-size: 200% 100%;
    box-shadow: 0 0 16px color-mix(in oklab, var(--color-watt) 55%, transparent);
    animation: bar-shimmer 2.8s linear infinite;
  }
  @keyframes bar-shimmer { to { background-position: -200% 0; } }
  @media (prefers-reduced-motion: reduce) { .winner .bar-fill { animation: none; } }
  .arch .bar-fill { background: color-mix(in oklab, var(--color-muted) 55%, transparent); }
  .numbers { display: flex; align-items: baseline; gap: 0.85rem; margin-top: 0.45rem; flex-wrap: wrap; }
  .numbers .sc { font-family: var(--font-display); font-weight: 700; font-size: 1.1rem; }
  .winner .numbers .sc { font-size: 1.55rem; color: var(--color-watt); letter-spacing: -0.02em; }
  .numbers .pr { font-family: var(--font-mono); font-size: 0.7rem; color: var(--color-faint); }
  .note { color: var(--color-muted); font-size: 0.84rem; line-height: 1.45; }
</style>
