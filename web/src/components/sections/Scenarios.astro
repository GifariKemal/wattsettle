---
import { Icon } from "astro-icon/components";
import Section from "../ui/Section.astro";
import { scenarios as sc } from "../../content/scenarios";
---
<Section
  id="pasar"
  label="Skenario"
  desc="8 pasar, satu rel, solar, CBAM, EV, karbon…"
  eyebrow={sc.eyebrow}
  title={sc.headline}
  lead={sc.lead}
>
  <div class="scen-grid">
    {sc.items.map((it, i) => (
      <div class:list={["scen rv", it.demo && "demo"]} data-delay={(i % 4) * 55} data-accent={it.accent}>
        <span class="scen-ic"><Icon name={it.icon} /></span>
        <div>
          <span class="scen-tag">{it.tag}</span>
          <h4>{it.title}</h4>
          <p>{it.body}</p>
        </div>
      </div>
    ))}
  </div>
</Section>

<style>
  .scen-grid { display: grid; gap: 0.9rem; grid-template-columns: 1fr; width: 100%; flex: 1; }
  @media (min-width: 560px) { .scen-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 920px) { .scen-grid { grid-template-columns: repeat(4, 1fr); grid-auto-rows: 1fr; } }

  .scen {
    padding: 1.25rem;
    border-radius: 1.15rem;
    border: 1px solid var(--edge);
    background: color-mix(in oklab, var(--color-ink) 2%, transparent);
    transition: transform 0.4s var(--ease-out-quint), border-color 0.4s ease;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .scen:hover { transform: translateY(-4px); }
  .scen[data-accent="watt"]:hover { border-color: color-mix(in oklab, var(--color-watt) 45%, transparent); }
  .scen[data-accent="flow"]:hover { border-color: color-mix(in oklab, var(--color-flow) 45%, transparent); }
  .scen[data-accent="gold"]:hover { border-color: color-mix(in oklab, var(--color-gold) 45%, transparent); }
  .scen[data-accent="heat"]:hover { border-color: color-mix(in oklab, var(--color-heat) 45%, transparent); }
  .scen[data-accent="volt"]:hover { border-color: color-mix(in oklab, var(--color-volt) 45%, transparent); }

  .scen-ic { display: inline-flex; font-size: 1.55rem; color: var(--color-faint); transition: transform 0.4s var(--ease-spring), color 0.4s ease; }
  .scen:hover .scen-ic { transform: translateY(-2px) scale(1.08); }
  .scen[data-accent="watt"] .scen-ic { color: var(--color-watt); }
  .scen[data-accent="flow"] .scen-ic { color: var(--color-flow); }
  .scen[data-accent="gold"] .scen-ic { color: var(--color-gold); }
  .scen[data-accent="heat"] .scen-ic { color: var(--color-heat); }
  .scen[data-accent="volt"] .scen-ic { color: var(--color-volt); }
  .scen-tag { font-family: var(--font-mono); font-size: 0.64rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-faint); }
  .scen h4 { font-size: 1.05rem; margin: 0.35rem 0 0.35rem; }
  .scen p { color: var(--color-muted); font-size: 0.85rem; line-height: 1.45; }

  .scen.demo {
    border-color: color-mix(in oklab, var(--color-flow) 50%, transparent);
    background:
      radial-gradient(90% 80% at 100% 0%, color-mix(in oklab, var(--color-flow) 14%, transparent), transparent 60%),
      linear-gradient(180deg, var(--color-panel), var(--color-panel-2));
  }
  .scen.demo .scen-tag { color: var(--color-flow); }
</style>
