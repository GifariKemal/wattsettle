---
import Section from "../ui/Section.astro";
import { references as r } from "../../content/why";
---
<Section
  id="referensi"
  eyebrow={r.eyebrow}
  title={r.headline}
>
  <div class="ref-grid">
    {r.items.map((it, i) => (
      <div class="ref rv" data-delay={i * 90}>
        <span class:list={["tag", `tag-${it.accent}`]}>{it.tag}</span>
        <h4>{it.title}</h4>
        <p>{it.body}</p>
        <div class="ref-link">→ {it.link}</div>
      </div>
    ))}
  </div>
</Section>

<style>
  .ref-grid { display: grid; gap: 1.25rem; grid-template-columns: 1fr; width: 100%; align-items: stretch; }
  @media (min-width: 800px) { .ref-grid { grid-template-columns: 1fr 1fr; } }
  .ref {
    padding: 1.9rem;
    border-radius: 1.3rem;
    border: 1px solid var(--edge);
    background: linear-gradient(180deg, var(--color-panel), var(--color-panel-2));
    display: flex;
    flex-direction: column;
    transition: transform 0.4s var(--ease-out-quint), border-color 0.4s;
  }
  .ref:hover { transform: translateY(-4px); border-color: var(--edge-strong); }
  .ref h4 { font-size: 1.5rem; margin: 0.85rem 0 0.5rem; }
  .ref p { color: var(--color-muted); font-size: 0.94rem; line-height: 1.6; }
  .ref-link {
    margin-top: auto; padding-top: 1rem;
    border-top: 1px solid var(--edge);
    font-family: var(--font-mono); font-size: 0.9rem; font-weight: 600;
    color: var(--color-watt); line-height: 1.4;
  }
</style>
