---
import { Icon } from "astro-icon/components";
import Section from "../ui/Section.astro";
import { moneyFlow as m } from "../../content/problem";
---
<Section
  id="uang"
  label="Aliran Uang"
  desc="Siapa bayar siapa, WattSettle jadi wasit + kasir"
  eyebrow={m.eyebrow}
  title={m.headline}
  lead={m.lead}
>
  <div class="money">
    <div class="party buyer rv">
      <span class="party-ic gold"><Icon name="ph:wallet" /></span>
      <span class="tag tag-gold">{m.buyer.tag}</span>
      <h4>{m.buyer.title}</h4>
      <ul>{m.buyer.items.map((i) => <li>{i}</li>)}</ul>
    </div>

    <div class="flow-arrow rv" data-delay="70" aria-hidden="true"><Icon name="ph:arrow-right" /></div>

    <div class="engine rv" data-delay="90">
      <span class="engine-ic"><Icon name="ph:scales" /></span>
      <div class="engine-badge">{m.engine.title}</div>
      <div class="engine-role">{m.engine.role}</div>
      <p>{m.engine.detail}</p>
    </div>

    <div class="flow-arrow rv" data-delay="110" aria-hidden="true"><Icon name="ph:arrow-right" /></div>

    <div class="party seller rv" data-delay="130">
      <span class="party-ic watt"><Icon name="ph:lightning-fill" /></span>
      <span class="tag tag-watt">{m.seller.tag}</span>
      <h4>{m.seller.title}</h4>
      <ul>{m.seller.items.map((i) => <li>{i}</li>)}</ul>
    </div>
  </div>
</Section>

<style>
  .money {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: 1fr;
    align-items: stretch;
    align-content: start;
    width: 100%;
    flex: 1;
  }
  @media (min-width: 900px) {
    .money { grid-template-columns: 1fr auto 1.1fr auto 1fr; align-items: stretch; }
  }
  .flow-arrow {
    display: none;
    place-items: center;
    font-size: 1.5rem;
    color: var(--color-flow);
  }
  @media (min-width: 900px) { .flow-arrow { display: grid; animation: arrow-pulse 1.9s ease-in-out infinite; } }
  .flow-arrow:last-of-type { animation-delay: 0.4s; }
  @keyframes arrow-pulse { 0%, 100% { opacity: 0.45; transform: translateX(0); } 50% { opacity: 1; transform: translateX(5px); } }
  @media (prefers-reduced-motion: reduce) { .flow-arrow { animation: none !important; opacity: 0.7; } }

  .party {
    padding: 1.6rem;
    border-radius: 1.3rem;
    border: 1px solid var(--edge);
    background: color-mix(in oklab, var(--color-ink) 2.5%, transparent);
    display: flex;
    flex-direction: column;
  }
  .party h4 { font-size: 1.15rem; margin: 0.5rem 0 0.85rem; }
  .party ul { list-style: none; display: flex; flex-direction: column; gap: 0.65rem; margin-top: auto; }
  .party li {
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.45;
    padding-left: 1.1rem;
    position: relative;
  }
  .party li::before { content: "→"; position: absolute; left: 0; color: var(--color-faint); }
  .party.buyer { border-color: color-mix(in oklab, var(--color-gold) 24%, transparent); }
  .party.seller { border-color: color-mix(in oklab, var(--color-watt) 24%, transparent); }
  .party-ic { display: inline-flex; font-size: 1.7rem; }
  .party-ic.gold { color: var(--color-gold); }
  .party-ic.watt { color: var(--color-watt); }

  .engine {
    text-align: center;
    padding: 1.8rem 1.4rem;
    border-radius: 1.4rem;
    border: 1px solid color-mix(in oklab, var(--color-flow) 42%, transparent);
    background:
      radial-gradient(120% 120% at 50% 0%, color-mix(in oklab, var(--color-flow) 14%, transparent), transparent 62%),
      linear-gradient(180deg, var(--color-panel), var(--color-panel-2));
    box-shadow: 0 24px 60px -30px color-mix(in oklab, var(--color-flow) 60%, transparent);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.15rem;
  }
  .engine-ic { display: inline-flex; font-size: 2rem; color: var(--color-flow); margin-bottom: 0.4rem; }
  .engine-badge { font-family: var(--font-display); font-weight: 700; letter-spacing: 0.04em; font-size: 1.25rem; color: var(--color-flow); }
  .engine-role { font-family: var(--font-display); font-weight: 700; margin: 0.35rem 0; }
  .engine p { color: var(--color-muted); font-size: 0.85rem; line-height: 1.5; }
</style>
