---
import Section from "../ui/Section.astro";
import SettleMachine from "../islands/SettleMachine.tsx";
import { machine } from "../../content/machine";
---
<Section
  id="mesin"
  eyebrow={machine.eyebrow}
  title={machine.title}
  lead={machine.lead}
>
  <div class="bezel sm-wrap rv">
    <div class="core">
      <SettleMachine client:load />
    </div>
  </div>
</Section>

<style>
  .sm-wrap { width: 100%; }
  .sm-wrap .core { padding: clamp(1rem, 2.2vw, 1.6rem); }
</style>
