---
import Section from "../ui/Section.astro";
import { problem } from "../../content/problem";
---
<Section
  id="masalah"
  eyebrow={problem.eyebrow}
  title={problem.headline}
  lead={problem.lead}
>
  <div class="prob-grid">
    <div class="prob-list">
      {problem.items.map((it, i) => (
        <div class="prob-item rv" data-delay={i * 80}>
          <span class="n">{it.n}</span>
          <div>
            <h4>{it.title}</h4>
            <p>{it.body}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="bezel prob-card rv" data-delay="120">
      <div class="core">
        <span class="eyebrow" style="color:var(--color-watt)">{problem.solution.kicker}</span>
        <h3>{problem.solution.headline}</h3>
        <p class="body">{problem.solution.body}</p>
        <div class="result"><b>Hasil:</b> {problem.solution.result}</div>
      </div>
    </div>
  </div>
</Section>

<style>
  .prob-grid {
    display: grid;
    gap: 1.1rem;
    grid-template-columns: 1fr;
    width: 100%;
  }
  @media (min-width: 940px) { .prob-grid { grid-template-columns: 1.05fr 0.95fr; align-items: stretch; } }

  .prob-list { display: flex; flex-direction: column; gap: 0.9rem; }
  .prob-item {
    display: flex;
    gap: 1rem;
    flex: 1;
    align-items: center;
    padding: 1.1rem 1.3rem;
    border-radius: 1.1rem;
    border: 1px solid var(--edge);
    background: color-mix(in oklab, var(--color-ink) 2%, transparent);
    transition: border-color 0.4s ease, transform 0.4s var(--ease-out-quint);
  }
  .prob-item:hover { border-color: var(--edge-strong); transform: translateX(4px); }
  .prob-item .n { font-family: var(--font-mono); font-size: 0.9rem; color: var(--color-heat); flex-shrink: 0; }
  .prob-item h4 { font-size: 1.05rem; margin-bottom: 0.25rem; }
  .prob-item p { color: var(--color-muted); font-size: 0.9rem; line-height: 1.5; }

  .prob-card { display: flex; }
  .prob-card .core { padding: 1.8rem; display: flex; flex-direction: column; justify-content: center; }
  .prob-card h3 { font-size: clamp(1.3rem, 2.2vw, 1.75rem); margin: 0.5rem 0 0.7rem; }
  .prob-card .body { color: var(--color-muted); line-height: 1.55; font-size: 0.95rem; }
  .prob-card .result {
    margin-top: 1.2rem;
    padding: 0.95rem 1.1rem;
    border-radius: 0.9rem;
    background: color-mix(in oklab, var(--color-watt) 8%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-watt) 25%, transparent);
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-ink);
  }
  .prob-card .result b { color: var(--color-watt); }
</style>
