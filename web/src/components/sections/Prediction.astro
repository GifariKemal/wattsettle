---
import Section from "../ui/Section.astro";
import { prediction as pr } from "../../content/why";
---
<Section
  id="prediksi"
  label="Prediksi"
  desc="Kenapa future-proof: RWA + Agentic Finance + settlement"
>
  <div class="predict rv">
    <span class="eyebrow">{pr.eyebrow}</span>
    <h2>{pr.headline}</h2>
    <p class="lead">{pr.lead}</p>
    <div class="pills">
      {pr.pills.map((p) => <span class="pill">{p}</span>)}
    </div>
    <p class="close">{pr.close}</p>
  </div>
</Section>

<style>
  .predict {
    padding: clamp(1.8rem, 4vw, 3rem);
    border-radius: 1.5rem;
    border: 1px solid var(--edge);
    width: 100%;
    background:
      radial-gradient(80% 90% at 0% 0%, color-mix(in oklab, var(--color-volt) 12%, transparent), transparent 55%),
      radial-gradient(80% 90% at 100% 100%, color-mix(in oklab, var(--color-flow) 10%, transparent), transparent 55%),
      linear-gradient(180deg, var(--color-panel), var(--color-panel-2));
  }
  .predict h2 { font-size: clamp(1.5rem, 3.2vw, 2.3rem); margin: 0.6rem 0; }
  .predict .lead { color: var(--color-muted); font-size: clamp(1rem, 1.5vw, 1.1rem); line-height: 1.65; max-width: 72ch; }
  .pills { display: flex; flex-wrap: wrap; gap: 0.6rem; margin: 1.5rem 0; }
  .pill {
    padding: 0.45rem 0.95rem;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--color-flow) 30%, transparent);
    background: linear-gradient(180deg, color-mix(in oklab, var(--color-flow) 12%, transparent), color-mix(in oklab, var(--color-ink) 3%, transparent));
    font-size: 0.82rem;
    color: var(--color-ink);
  }
  .predict .close { color: var(--color-muted); font-size: 0.92rem; line-height: 1.6; max-width: 70ch; }
</style>
