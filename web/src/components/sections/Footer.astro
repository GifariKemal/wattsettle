---
import { footer as f, site } from "../../content/site";
---
<footer class="deck-page foot" id="penutup">
  <div class="container">
    <span class="eyebrow rv" style="justify-content:center">{f.eyebrow}</span>
    <h2 class="rv" data-delay="80">
      {f.headline.map((l) => <span class="line">{l}</span>)}
    </h2>
    <p class="lead rv" data-delay="160">{f.lead}</p>

    <div class="foot-cta rv" data-delay="220">
      <a href="/" class="btn btn-primary">Kembali ke awal <span class="ic">↑</span></a>
      <a href="/simulator" class="btn btn-ghost">Ulangi simulasi <span class="ic">↻</span></a>
    </div>

    <div class="bism rv" data-delay="280">{f.bismillah}</div>
    <div class="fmeta">
      {site.builder.company} · {site.builder.name} · {site.event.name}
    </div>
  </div>
</footer>

<style>
  .foot {
    justify-content: center;
    text-align: center;
    background: radial-gradient(70% 90% at 50% 100%, color-mix(in oklab, var(--color-watt) 8%, transparent), transparent 60%);
  }
  .foot h2 {
    font-size: clamp(2rem, 5.5vw, 4rem);
    margin: 1.2rem auto;
    max-width: 20ch;
  }
  .foot h2 .line { display: block; }
  .foot .lead {
    color: var(--color-muted);
    font-size: clamp(1rem, 1.7vw, 1.2rem);
    line-height: 1.6;
    max-width: 60ch;
    margin: 0 auto;
  }
  .foot-cta { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.9rem; margin-top: 2.4rem; }
  .bism {
    margin-top: 3rem;
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--color-watt);
  }
  .fmeta {
    margin-top: 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--color-faint);
    letter-spacing: 0.03em;
  }
</style>
