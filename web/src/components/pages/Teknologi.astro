---
import { Icon } from "astro-icon/components";
import { site } from "../../content/site";
import { techHero, contract, guards, verifier, chainIntegration, token, proof } from "../../content/tech";

const scanBase = site.chain.scan;
const tokenUrl = `${scanBase}/token/${site.chain.token}`;
const contractUrl = `${scanBase}/address/${site.chain.token}`;
const txUrl = `${scanBase}/txs`;
const proofHref = [contractUrl, tokenUrl, txUrl];
---

<!-- HERO -->
<section class="section-pad tech-hero">
  <div class="container">
    <span class="eyebrow rv">{techHero.eyebrow}</span>
    <h1 class="hero-head">
      {techHero.headline.map((line, i) => (
        <span class="block rv">{i === techHero.headline.length - 1 ? <span class="text-gradient-watt">{line}</span> : line}</span>
      ))}
    </h1>
    <p class="hero-lead rv">{techHero.lead}</p>
    <ul class="chain-strip rv">
      <li><span class="tag tag-flow">chainId {site.chain.chainId}</span></li>
      <li><span class="tag tag-gold">{site.chain.tokenSymbol} verified</span></li>
      <li><span class="tag tag-watt">ERC-8004 live</span></li>
    </ul>
  </div>
</section>

<!-- LAPIS 1: KONTRAK -->
<section class="section-pad">
  <div class="container">
    <header class="sec-head rv">
      <span class="eyebrow">{contract.eyebrow}</span>
      <h2 class="sec-title">{contract.title}</h2>
      <p class="sec-lead">{contract.lead}</p>
    </header>

    <div class="split">
      <ul class="pt-list">
        {contract.points.map((p) => (
          <li class={`pt-card rv tone-${p.tone}`} data-spot>
            <Icon name={p.ic} class="pt-ic" />
            <strong class="pt-t">{p.t}</strong>
            <span class="pt-d">{p.d}</span>
          </li>
        ))}
      </ul>

      <figure class="code-card bezel rv" data-spot>
        <div class="core">
          <figcaption class="code-cap">
            <span class="dots" aria-hidden="true"><i></i><i></i><i></i></span>
            <span class="code-file">WattSettle.sol</span>
          </figcaption>
          <pre><code>{contract.code}</code></pre>
        </div>
      </figure>
    </div>
  </div>
</section>

<!-- TRUST BOUNDARY / GUARDS -->
<section class="section-pad">
  <div class="container">
    <header class="sec-head rv">
      <span class="eyebrow">{guards.eyebrow}</span>
      <h2 class="sec-title">{guards.title}</h2>
      <p class="sec-lead">{guards.lead}</p>
    </header>
    <ul class="guard-grid">
      {guards.items.map((g) => (
        <li class={`guard-card rv tone-${g.tone}`} data-spot>
          <Icon name={g.ic} class="guard-ic" />
          <strong class="guard-t">{g.t}</strong>
          <span class="guard-d">{g.d}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<!-- LAPIS 2: AI VERIFIER -->
<section class="section-pad">
  <div class="container">
    <header class="sec-head rv">
      <span class="eyebrow">{verifier.eyebrow}</span>
      <h2 class="sec-title">{verifier.title}</h2>
      <p class="sec-lead">{verifier.lead}</p>
    </header>

    <ol class="loop-flow">
      {verifier.steps.map((s, i) => (
        <li class={`loop-card rv tone-${s.tone}`} data-spot>
          <span class="loop-num">{s.k}</span>
          <Icon name={s.ic} class="loop-ic" />
          <strong class="loop-t">{s.t}</strong>
          <span class="loop-d">{s.d}</span>
          {i < verifier.steps.length - 1 && <span class="loop-arrow" aria-hidden="true">→</span>}
        </li>
      ))}
    </ol>

    <div class="split split-flip">
      <figure class="code-card bezel rv" data-spot>
        <div class="core">
          <figcaption class="code-cap">
            <span class="dots" aria-hidden="true"><i></i><i></i><i></i></span>
            <span class="code-file">verifier.py</span>
          </figcaption>
          <pre><code>{verifier.code}</code></pre>
        </div>
      </figure>

      <aside class="note-card bezel rv" data-spot>
        <div class="core">
          <span class="tag tag-flow">Deterministik</span>
          <p class="note-body">{verifier.note}</p>
        </div>
      </aside>
    </div>
  </div>
</section>

<!-- LAPIS 3: BNB CHAIN + ERC-8004 -->
<section class="section-pad">
  <div class="container">
    <header class="sec-head rv">
      <span class="eyebrow">{chainIntegration.eyebrow}</span>
      <h2 class="sec-title">{chainIntegration.title}</h2>
      <p class="sec-lead">{chainIntegration.lead}</p>
    </header>
    <ul class="pt-list pt-3">
      {chainIntegration.points.map((p) => (
        <li class={`pt-card rv tone-${p.tone}`} data-spot>
          <Icon name={p.ic} class="pt-ic" />
          <strong class="pt-t">{p.t}</strong>
          <span class="pt-d">{p.d}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<!-- TOKEN -->
<section class="section-pad">
  <div class="container">
    <div class="token-wrap bezel rv" data-spot>
      <div class="core">
        <div class="token-head">
          <span class="eyebrow">{token.eyebrow}</span>
          <h2 class="sec-title">{token.title}</h2>
          <p class="sec-lead">{token.lead}</p>
        </div>
        <ul class="token-facts">
          {token.facts.map((f) => (
            <li class="fact">
              <span class="fact-k tag tag-gold">{f.k}</span>
              <strong class="fact-v">{f.v}</strong>
              <span class="fact-d">{f.d}</span>
            </li>
          ))}
        </ul>
        <p class="token-framing">{token.framing}</p>
        <p class="token-addr">
          <span class="addr-label">Address</span>
          <a href={tokenUrl} class="addr-link" target="_blank" rel="noopener">{site.chain.token}</a>
        </p>
      </div>
    </div>
  </div>
</section>

<!-- BUKTI ON-CHAIN -->
<section class="section-pad">
  <div class="container">
    <header class="sec-head rv">
      <span class="eyebrow">{proof.eyebrow}</span>
      <h2 class="sec-title">{proof.title}</h2>
      <p class="sec-lead">{proof.lead}</p>
    </header>
    <div class="proof-links">
      {proof.links.map((l, i) => (
        <a href={proofHref[i]} class={`proof-link rv tone-${l.tone}`} data-spot target="_blank" rel="noopener">
          <Icon name={l.ic} class="proof-ic" />
          <span class="proof-t">{l.t}<span class="proof-arrow">→</span></span>
          <span class="proof-d">{l.d}</span>
          <span class="proof-scan">{new URL(scanBase).host}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  /* HERO */
  .tech-hero { padding-top: clamp(2.5rem, 7vw, 5rem); }
  .hero-head { font-size: clamp(2.1rem, 5.2vw, 3.9rem); line-height: 1.03; }
  .hero-head .block { display: block; }
  .eyebrow.rv { margin-bottom: 1.1rem; }
  .hero-lead { margin: 1.4rem 0 1.8rem; max-width: 68ch; color: var(--color-muted); font-size: clamp(1rem, 1.5vw, 1.16rem); line-height: 1.6; }
  .chain-strip { list-style: none; display: flex; flex-wrap: wrap; gap: 0.6rem; }

  /* SECTION HEAD (selaras Home) */
  .sec-head { max-width: 66ch; margin-bottom: clamp(2rem, 4vw, 3rem); }
  .sec-title { font-size: clamp(1.7rem, 3.5vw, 2.7rem); margin-top: 0.6rem; }
  .sec-lead { margin-top: 0.8rem; color: var(--color-muted); font-size: clamp(0.98rem, 1.4vw, 1.12rem); line-height: 1.6; }

  /* SPLIT: kartu poin + code */
  .split { display: grid; gap: 1.25rem; align-items: start; }
  .split > * { min-width: 0; }
  .code-card, .code-card .core { min-width: 0; max-width: 100%; }
  @media (min-width: 960px) { .split { grid-template-columns: 0.85fr 1.15fr; } }
  @media (min-width: 960px) { .split-flip { grid-template-columns: 1.15fr 0.85fr; } }

  .pt-list { list-style: none; display: grid; gap: 0.9rem; }
  .pt-3 { gap: 1rem; }
  @media (min-width: 720px) { .pt-3 { grid-template-columns: repeat(3, 1fr); } }
  .pt-card {
    position: relative; padding: 1.3rem 1.25rem; border-radius: 1.25rem;
    border: 1px solid var(--edge); background: color-mix(in oklab, var(--color-ink) 3%, transparent);
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .pt-ic { width: 1.8rem; height: 1.8rem; }
  .tone-flow .pt-ic, .tone-flow .guard-ic { color: var(--color-flow); }
  .tone-gold .pt-ic, .tone-gold .guard-ic { color: var(--color-gold); }
  .tone-volt .pt-ic, .tone-volt .guard-ic { color: var(--color-volt); }
  .tone-watt .pt-ic, .tone-watt .guard-ic { color: var(--color-watt); }
  .pt-t { font-family: var(--font-display); font-size: 1.18rem; }
  .pt-d { color: var(--color-faint); font-size: 0.9rem; line-height: 1.55; }

  /* CODE CARD */
  .code-card .core { padding: 0; overflow: hidden; }
  .code-cap {
    display: flex; align-items: center; gap: 0.7rem;
    padding: 0.7rem 1.1rem; border-bottom: 1px solid var(--edge);
  }
  .dots { display: inline-flex; gap: 0.35rem; }
  .dots i { width: 0.6rem; height: 0.6rem; border-radius: 999px; background: color-mix(in oklab, var(--color-ink) 18%, transparent); }
  .dots i:first-child { background: color-mix(in oklab, var(--color-heat) 60%, transparent); }
  .dots i:nth-child(2) { background: color-mix(in oklab, var(--color-gold) 60%, transparent); }
  .dots i:last-child { background: color-mix(in oklab, var(--color-watt) 60%, transparent); }
  .code-file { font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.04em; color: var(--color-muted); }
  .code-card pre {
    margin: 0; padding: 1.15rem 1.25rem; overflow-x: auto;
    background: color-mix(in oklab, var(--color-void) 55%, transparent);
    font-family: var(--font-mono); font-size: 0.78rem; line-height: 1.62;
    color: var(--color-ink); tab-size: 2;
  }
  .code-card code { font-family: inherit; color: color-mix(in oklab, var(--color-ink) 88%, var(--color-flow)); white-space: pre; }

  /* GUARD GRID */
  .guard-grid { list-style: none; display: grid; gap: 1rem; }
  @media (min-width: 640px) { .guard-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1000px) { .guard-grid { grid-template-columns: repeat(4, 1fr); } }
  .guard-card {
    padding: 1.35rem 1.2rem; border-radius: 1.25rem;
    border: 1px solid var(--edge); background: color-mix(in oklab, var(--color-ink) 3%, transparent);
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .guard-ic { width: 1.7rem; height: 1.7rem; }
  .guard-t { font-family: var(--font-display); font-size: 1.08rem; }
  .guard-d { color: var(--color-faint); font-size: 0.86rem; line-height: 1.55; }

  /* LOOP FLOW (selaras Home) */
  .loop-flow { list-style: none; display: grid; gap: 1rem; margin-bottom: 1.5rem; }
  @media (min-width: 720px) { .loop-flow { grid-template-columns: repeat(4, 1fr); gap: 0.75rem; } }
  .loop-card {
    position: relative; padding: 1.4rem 1.25rem; border-radius: 1.25rem;
    border: 1px solid var(--edge); background: color-mix(in oklab, var(--color-ink) 3%, transparent);
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .loop-num { font-family: var(--font-mono); font-size: 0.78rem; color: var(--color-faint); }
  .loop-ic { width: 1.9rem; height: 1.9rem; }
  .tone-flow .loop-ic { color: var(--color-flow); }
  .tone-gold .loop-ic { color: var(--color-gold); }
  .tone-volt .loop-ic { color: var(--color-volt); }
  .tone-watt .loop-ic { color: var(--color-watt); }
  .loop-t { font-family: var(--font-display); font-size: 1.15rem; }
  .loop-d { color: var(--color-faint); font-size: 0.86rem; line-height: 1.5; }
  .loop-arrow { position: absolute; right: -0.55rem; top: 50%; transform: translateY(-50%); color: var(--color-line); font-size: 1.1rem; z-index: 2; }
  @media (max-width: 719px) { .loop-arrow { right: 50%; top: auto; bottom: -0.9rem; transform: translateX(50%) rotate(90deg); } }

  /* NOTE CARD */
  .note-card .core { padding: clamp(1.4rem, 3vw, 2rem); display: flex; flex-direction: column; gap: 0.9rem; }
  .note-body { color: var(--color-muted); line-height: 1.65; font-size: 0.98rem; }

  /* TOKEN */
  .token-wrap .core { padding: clamp(1.6rem, 4vw, 2.8rem); }
  .token-head { max-width: 68ch; }
  .token-facts { list-style: none; display: grid; gap: 1rem; margin: 1.8rem 0; }
  @media (min-width: 640px) { .token-facts { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 980px) { .token-facts { grid-template-columns: repeat(4, 1fr); } }
  .fact {
    display: flex; flex-direction: column; gap: 0.4rem;
    padding: 1.15rem 1.15rem; border-radius: 1rem;
    border: 1px solid var(--edge); background: color-mix(in oklab, var(--color-ink) 3%, transparent);
  }
  .fact-k { align-self: flex-start; }
  .fact-v { font-family: var(--font-display); font-size: 1.4rem; color: var(--color-ink); }
  .fact-d { color: var(--color-faint); font-size: 0.82rem; line-height: 1.5; }
  .token-framing { max-width: 74ch; color: var(--color-muted); line-height: 1.65; }
  .token-addr {
    margin-top: 1.4rem; display: flex; flex-wrap: wrap; align-items: center; gap: 0.6rem;
    padding-top: 1.2rem; border-top: 1px solid var(--edge);
  }
  .addr-label { font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.24em; text-transform: uppercase; color: var(--color-faint); }
  .addr-link { font-family: var(--font-mono); font-size: 0.82rem; color: var(--color-flow); text-decoration: none; word-break: break-all; }
  .addr-link:hover { text-decoration: underline; }

  /* PROOF LINKS */
  .proof-links { display: grid; gap: 1rem; }
  @media (min-width: 720px) { .proof-links { grid-template-columns: repeat(3, 1fr); } }
  .proof-link {
    display: flex; flex-direction: column; gap: 0.5rem; text-decoration: none;
    padding: 1.4rem 1.35rem; border-radius: 1.25rem; border: 1px solid var(--edge);
    background: color-mix(in oklab, var(--color-ink) 3%, transparent);
    transition: transform 0.4s var(--ease-spring), border-color 0.3s;
  }
  .proof-link:hover { transform: translateY(-3px); border-color: color-mix(in oklab, var(--color-flow) 40%, transparent); }
  .proof-ic { width: 1.7rem; height: 1.7rem; }
  .tone-flow .proof-ic { color: var(--color-flow); }
  .tone-gold .proof-ic { color: var(--color-gold); }
  .tone-watt .proof-ic { color: var(--color-watt); }
  .proof-t { font-family: var(--font-display); font-weight: 600; font-size: 1.12rem; color: var(--color-ink); display: flex; align-items: center; gap: 0.4rem; }
  .proof-arrow { transition: transform 0.4s var(--ease-spring); }
  .proof-link:hover .proof-arrow { transform: translateX(4px); }
  .proof-d { color: var(--color-faint); font-size: 0.88rem; line-height: 1.5; }
  .proof-scan { margin-top: 0.3rem; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.04em; color: var(--color-muted); }
</style>
