---
import { Icon } from "astro-icon/components";
import { hero } from "../../content/site";
import { about, loop, thesis, teasers } from "../../content/home";
---

<!-- HERO -->
<section class="section-pad hero-sec">
  <div class="container hero-grid">
    <div class="hero-copy">
      <span class="eyebrow rv">{hero.kicker}</span>
      <h1 class="hero-head">
        {hero.headline.map((line, i) => (
          <span class="block rv">{i === hero.headline.length - 1 ? <span class="text-gradient-watt">{line}</span> : line}</span>
        ))}
      </h1>
      <p class="hero-lead rv">{hero.lead}</p>
      <div class="hero-ctas rv">
        {hero.ctas.map((c) => (
          <a href={c.href} class={`btn ${c.kind === "primary" ? "btn-primary" : "btn-ghost"}`}>{c.label}<span class="ic">→</span></a>
        ))}
      </div>
    </div>

    <ul class="proof">
      {hero.proof.map((p) => (
        <li class="proof-card bezel rv" data-spot>
          <div class="core">
            <span class="proof-k tag tag-flow">{p.k}</span>
            <strong class="proof-v">{p.v}</strong>
            <span class="proof-d">{p.d}</span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<!-- APA ITU WATTSETTLE -->
<section class="section-pad">
  <div class="container">
    <header class="sec-head rv">
      <span class="eyebrow">{about.eyebrow}</span>
      <h2 class="sec-title">{about.title}</h2>
      <p class="sec-lead">{about.lead}</p>
    </header>
    <div class="about-cards">
      {about.cards.map((c) => (
        <article class={`about-card rv tone-${c.tone}`} data-spot>
          <Icon name={c.ic} class="about-ic" />
          <strong class="about-t">{c.t}</strong>
          <p class="about-d">{c.d}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- LOOP -->
<section class="section-pad">
  <div class="container">
    <header class="sec-head rv">
      <span class="eyebrow">{loop.eyebrow}</span>
      <h2 class="sec-title">{loop.title}</h2>
      <p class="sec-lead">{loop.lead}</p>
    </header>
    <ol class="loop-flow">
      {loop.steps.map((s, i) => (
        <li class={`loop-card rv tone-${s.tone}`} data-spot>
          <span class="loop-num">{s.k}</span>
          <Icon name={s.ic} class="loop-ic" />
          <strong class="loop-t">{s.t}</strong>
          <span class="loop-d">{s.d}</span>
          {i < loop.steps.length - 1 && <span class="loop-arrow" aria-hidden="true">→</span>}
        </li>
      ))}
    </ol>
  </div>
</section>

<!-- THESIS -->
<section class="section-pad">
  <div class="container">
    <blockquote class="thesis bezel rv" data-spot>
      <div class="core">
        <span class="eyebrow">{thesis.eyebrow}</span>
        <p class="thesis-q">{thesis.quote}</p>
        <p class="thesis-b">{thesis.body}</p>
      </div>
    </blockquote>
  </div>
</section>

<!-- TEASERS -->
<section class="section-pad">
  <div class="container">
    <div class="teasers">
      {teasers.map((t) => (
        <a href={t.href} class="teaser rv" data-spot>
          <Icon name={t.ic} class="teaser-ic" />
          <span class="teaser-t">{t.label}<span class="teaser-arrow">→</span></span>
          <span class="teaser-d">{t.d}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .hero-sec { padding-top: clamp(2.5rem, 7vw, 5rem); }
  .hero-grid { display: grid; gap: clamp(2rem, 5vw, 4rem); align-items: center; }
  @media (min-width: 960px) { .hero-grid { grid-template-columns: 1.15fr 0.85fr; } }
  .hero-head { font-size: clamp(2.4rem, 6vw, 4.4rem); line-height: 1.02; }
  .hero-head .block { display: block; }
  .eyebrow.rv { margin-bottom: 1.1rem; }
  .hero-lead { margin: 1.4rem 0 2rem; max-width: 56ch; color: var(--color-muted); font-size: clamp(1rem, 1.5vw, 1.18rem); line-height: 1.6; }
  .hero-ctas { display: flex; flex-wrap: wrap; gap: 0.7rem; }

  .proof { list-style: none; display: grid; gap: 0.9rem; }
  .proof-card .core { padding: 1.15rem 1.25rem; display: flex; flex-direction: column; gap: 0.35rem; }
  .proof-k { align-self: flex-start; }
  .proof-v { font-family: var(--font-display); font-size: 1.35rem; }
  .proof-d { color: var(--color-faint); font-size: 0.9rem; line-height: 1.5; }

  .sec-head { max-width: 62ch; margin-bottom: clamp(2rem, 4vw, 3rem); }
  .sec-title { font-size: clamp(1.7rem, 3.5vw, 2.7rem); margin-top: 0.6rem; }
  .sec-lead { margin-top: 0.8rem; color: var(--color-muted); font-size: clamp(0.98rem, 1.4vw, 1.12rem); line-height: 1.6; }

  .about-cards { display: grid; gap: 1rem; }
  @media (min-width: 760px) { .about-cards { grid-template-columns: 1fr 1fr; } }
  .about-card {
    padding: clamp(1.5rem, 3vw, 2rem); border-radius: 1.25rem;
    border: 1px solid var(--edge); background: color-mix(in oklab, var(--color-ink) 3%, transparent);
    display: flex; flex-direction: column; gap: 0.7rem;
  }
  .about-ic { width: 2rem; height: 2rem; }
  .tone-heat .about-ic { color: var(--color-heat); }
  .tone-watt .about-ic { color: var(--color-watt); }
  .about-t { font-family: var(--font-display); font-size: 1.25rem; }
  .about-d { color: var(--color-muted); font-size: 0.95rem; line-height: 1.6; }

  .loop-flow { list-style: none; display: grid; gap: 1rem; }
  @media (min-width: 720px) { .loop-flow { grid-template-columns: repeat(4, 1fr); gap: 0.75rem; } }
  .loop-card {
    position: relative; padding: 1.4rem 1.25rem; border-radius: 1.25rem;
    border: 1px solid var(--edge); background: color-mix(in oklab, var(--color-ink) 3%, transparent);
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .loop-num { font-family: var(--font-mono); font-size: 0.78rem; color: var(--color-faint); }
  .loop-ic { width: 1.9rem; height: 1.9rem; }
  .tone-flow .loop-ic { color: var(--color-flow); }
  .tone-gold .loop-ic { color: var(--color-gold); }
  .tone-volt .loop-ic { color: var(--color-volt); }
  .tone-watt .loop-ic { color: var(--color-watt); }
  .loop-t { font-family: var(--font-display); font-size: 1.2rem; }
  .loop-d { color: var(--color-faint); font-size: 0.88rem; line-height: 1.5; }
  .loop-arrow { position: absolute; right: -0.55rem; top: 50%; transform: translateY(-50%); color: var(--color-line); font-size: 1.1rem; z-index: 2; }
  @media (max-width: 719px) { .loop-arrow { right: 50%; top: auto; bottom: -0.9rem; transform: translateX(50%) rotate(90deg); } }

  .thesis .core { padding: clamp(1.6rem, 4vw, 2.8rem); }
  .thesis-q { font-family: var(--font-display); font-weight: 700; font-size: clamp(1.4rem, 3vw, 2.1rem); line-height: 1.18; letter-spacing: -0.02em; margin-top: 0.6rem; }
  .thesis-b { margin-top: 1rem; max-width: 70ch; color: var(--color-muted); line-height: 1.65; }

  .teasers { display: grid; gap: 1rem; }
  @media (min-width: 720px) { .teasers { grid-template-columns: repeat(3, 1fr); } }
  .teaser {
    display: flex; flex-direction: column; gap: 0.5rem; text-decoration: none;
    padding: 1.4rem 1.35rem; border-radius: 1.25rem; border: 1px solid var(--edge);
    background: color-mix(in oklab, var(--color-ink) 3%, transparent);
    transition: transform 0.4s var(--ease-spring), border-color 0.3s;
  }
  .teaser:hover { transform: translateY(-3px); border-color: color-mix(in oklab, var(--color-flow) 40%, transparent); }
  .teaser-ic { width: 1.7rem; height: 1.7rem; color: var(--color-flow); }
  .teaser-t { font-family: var(--font-display); font-weight: 600; font-size: 1.15rem; color: var(--color-ink); display: flex; align-items: center; gap: 0.4rem; }
  .teaser-arrow { transition: transform 0.4s var(--ease-spring); }
  .teaser:hover .teaser-arrow { transform: translateX(4px); }
  .teaser-d { color: var(--color-faint); font-size: 0.9rem; line-height: 1.5; }
</style>
