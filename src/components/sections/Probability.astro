---
import Section from "../ui/Section.astro";
import { probability as p } from "../../content/scoring";
const accentVar = (a: string) =>
  a === "watt" ? "var(--color-watt)" : a === "flow" ? "var(--color-flow)" : a === "gold" ? "var(--color-gold)" : "var(--color-ink)";
---
<Section
  id="peluang"
  label="Peluang"
  desc="Angka jujur: nominasi & juara, tanpa inflasi"
  eyebrow={p.eyebrow}
  title={p.headline}
  lead={p.lead}
>
  <div class="stat-grid">
    {p.stats.map((s, i) => (
      <div class="stat rv" data-delay={i * 70}>
        <div class="big" style={`color:${accentVar(s.accent)}`}
          data-count={s.value} data-prefix={s.prefix ?? ""} data-suffix={s.suffix}>
          {s.prefix ?? ""}{s.value}{s.suffix}
        </div>
        <div class="lab">{s.label}</div>
      </div>
    ))}
  </div>
</Section>

<style>
  .stat-grid { display: grid; gap: 1rem; grid-template-columns: repeat(2, 1fr); width: 100%; }
  @media (min-width: 820px) { .stat-grid { grid-template-columns: repeat(4, 1fr); } }
  .stat {
    padding: 2rem 1.5rem;
    border-radius: 1.3rem;
    border: 1px solid var(--edge);
    background:
      radial-gradient(130% 90% at 50% 0%, color-mix(in oklab, var(--color-flow) 10%, transparent), transparent 60%),
      linear-gradient(180deg, var(--color-panel), color-mix(in oklab, var(--color-panel-2) 55%, transparent));
    box-shadow: inset 0 1px 0 color-mix(in oklab, var(--color-ink) 12%, transparent);
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    transition: transform 0.4s var(--ease-out-quint), border-color 0.4s;
  }
  .stat:hover { transform: translateY(-4px); border-color: var(--edge-strong); }
  .stat .big { font-family: var(--font-display); font-weight: 700; font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.02em; }
  .stat .lab { color: var(--color-faint); font-size: 0.84rem; line-height: 1.35; }
</style>
