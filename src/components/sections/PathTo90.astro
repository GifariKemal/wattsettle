---
import Section from "../ui/Section.astro";
import { pathTo90 as path } from "../../content/scoring";
---
<Section
  id="path"
  label="Path-to-90"
  desc="Checklist yang harus benar untuk menang"
  eyebrow={path.eyebrow}
  title={path.headline}
>
  <ol class="path">
    {path.items.map((it, i) => (
      <li class="rv" data-delay={(i % 2) * 60 + Math.floor(i / 2) * 40}>
        <span class="pn">{String(i + 1).padStart(2, "0")}</span>
        <span set:html={it.replace(/(@\w+)/g, '<b>$1</b>')}></span>
      </li>
    ))}
  </ol>
</Section>

<style>
  .path { list-style: none; display: grid; gap: 0.75rem; width: 100%; grid-template-columns: 1fr; align-content: start; flex: 1; }
  @media (min-width: 780px) { .path { grid-template-columns: 1fr 1fr; } }
  .path li {
    display: flex;
    gap: 0.9rem;
    align-items: flex-start;
    padding: 1rem 1.2rem;
    border-radius: 1rem;
    border: 1px solid var(--edge);
    border-left: 2px solid color-mix(in oklab, var(--color-watt) 40%, transparent);
    background: linear-gradient(100deg, color-mix(in oklab, var(--color-watt) 6%, transparent), color-mix(in oklab, var(--color-ink) 3%, transparent) 40%);
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.5;
    transition: border-color 0.4s, transform 0.4s var(--ease-out-quint);
  }
  .path li:hover { border-color: color-mix(in oklab, var(--color-flow) 40%, transparent); transform: translateY(-2px); }
  .path li b { color: var(--color-flow); font-weight: 600; }
  .path .pn { font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-watt); flex-shrink: 0; padding-top: 0.05rem; }
</style>
